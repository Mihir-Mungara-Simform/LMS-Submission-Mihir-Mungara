      <column caption='Aircraft Desc' datatype='string' name='[AIRCRAFT_DESC]' role='dimension' type='nominal' />
      <column caption='Aircraft Family' datatype='string' name='[AIRCRAFT_FAMILY]' role='dimension' type='nominal' />
      <column caption='Aircraft Type' datatype='string' name='[AIRCRAFT_TYPE]' role='dimension' type='nominal' />
      <column caption='Alt Baro' datatype='integer' name='[ALT_BARO]' role='measure' type='quantitative' />
      <column caption='Alt Geom' datatype='integer' name='[ALT_GEOM]' role='measure' type='quantitative' />
      <column caption='Average Altitude' datatype='string' name='[Average Speed (copy)_0437621237260296]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Average Altitude&quot;' />
      </column>
      <column caption='Baro Rate' datatype='real' name='[BARO_RATE]' role='measure' type='quantitative' />
      <column caption='Category' datatype='string' name='[CATEGORY]' role='dimension' type='nominal' />
      <column caption='Category Label' datatype='string' name='[CATEGORY_LABEL]' role='dimension' type='nominal' />
      <column caption='Live Status' datatype='string' name='[Calculation_0302656252784642]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;● Live | Updates every 5 min&quot;' />
      </column>
      <column caption='Altitude Context' datatype='string' name='[Calculation_0302656254930950]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;● Barometric Altitude | Feet (ft)&quot;' />
      </column>
      <column caption='Heavy Context' datatype='string' name='[Calculation_0302656255115271]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;● ADS-B Category A5 Aircraft&quot;' />
      </column>
      <column caption='Altitude Band' datatype='string' name='[Calculation_0302656257601544]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ALT_BARO] &gt;= 40000 THEN &quot;FL400+ (High Cruise)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 35000 THEN &quot;FL350-400 (Cruise)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 30000 THEN &quot;FL300-350 (Cruise)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 25000 THEN &quot;FL250-300 (Cruise)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 20000 THEN &quot;FL200-250 (Transition)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 10000 THEN &quot;FL100-200 (Climb/Descent)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt; 0     THEN &quot;Below FL100 (Approach)&quot;&#13;&#10;ELSE &quot;Ground&quot;&#13;&#10;END' />
      </column>
      <column caption='Flight Origin' datatype='string' name='[Calculation_0302656257687561]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEFT([REGISTRATION], 2) = &quot;VT&quot; THEN&#13;&#10;    &quot;Domestic&quot;&#13;&#10;ELSEIF ISNULL([REGISTRATION]) THEN&#13;&#10;    &quot;Unknown&quot;&#13;&#10;ELSE&#13;&#10;    &quot;International 🌍&quot;&#13;&#10;END' />
      </column>
      <column caption='Squawk Alert' datatype='string' name='[Calculation_0302656258211850]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [SQUAWK] = &quot;7500&quot; THEN &quot;🚨 HIJACK (7500)&quot;&#13;&#10;ELSEIF [SQUAWK] = &quot;7600&quot; THEN &quot;📻 RADIO FAIL (7600)&quot;&#13;&#10;ELSEIF [SQUAWK] = &quot;7700&quot; THEN &quot;⚠️ EMERGENCY (7700)&quot;&#13;&#10;ELSE &quot;✅ Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Emergency Count' datatype='integer' name='[Calculation_0302656258301963]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [SQUAWK] IN (&quot;7500&quot;, &quot;7600&quot;, &quot;7700&quot;) THEN 1 ELSE 0 END' />
      </column>
      <column caption='Climbing Count' datatype='integer' name='[Calculation_0302656258396172]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [VERTICAL_TREND] = &quot;Climbing&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Descending Count' datatype='integer' name='[Calculation_0302656258461709]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [VERTICAL_TREND] = &quot;Descending&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Level Count' datatype='integer' name='[Calculation_0302656258633742]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [VERTICAL_TREND] = &quot;Level&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Ground_Flights' datatype='integer' name='[Calculation_0302656263254031]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [FLIGHT_PHASE] = &quot;Ground/Taxi&quot; THEN [HEX] END)' />
      </column>
      <column caption='Total Aircraft' datatype='integer' name='[Calculation_0302656274030608]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([HEX])' />
      </column>
      <column caption='Approaching' datatype='integer' name='[Calculation_0302656274157585]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [VERTICAL_TREND] = &quot;Descending&quot; THEN [HEX] END)' />
      </column>
      <column caption='Departing' datatype='integer' name='[Calculation_0302656274444306]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [VERTICAL_TREND] = &quot;Climbing&quot; THEN [HEX] END)' />
      </column>
      <column caption='On Ground' datatype='integer' name='[Calculation_0302656274673683]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [FLIGHT_PHASE] = &quot;Ground/Taxi&quot; THEN [HEX] END)' />
      </column>
      <column caption='Last Updated Text' datatype='string' name='[Calculation_0302656285683733]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Last Updated: &quot;&#13;&#10;+&#13;&#10;STR(&#13;&#10;    { FIXED : MAX([SNAPSHOT_TS]) }&#13;&#10;)' />
      </column>
      <column caption='Latest Snapshot' datatype='boolean' name='[Calculation_0437621223886848]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[SNAPSHOT_TS] =&#13;&#10;{ FIXED : MAX([SNAPSHOT_TS]) }' />
      </column>
      <column caption='Total Active Flights' datatype='string' name='[Calculation_0437621234962438]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Total Active Flights&quot;' />
      </column>
      <column caption='Heavy Count' datatype='integer' name='[Calculation_0437621237907466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [IS_HEAVY] = TRUE THEN [HEX] END)' />
      </column>
      <column caption='Heavy Aircraft Count' datatype='string' name='[Calculation_0437621238276107]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Heavy Aircraft Count&quot;' />
      </column>
      <column caption='Airline Code' datatype='string' name='[Calculation_0437621241098252]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([FLIGHT], 3)' />
      </column>
