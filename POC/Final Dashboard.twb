    <worksheet name='Altitude Bands'>
      <table>
        <view>
          <datasources>
            <datasource caption='FCT_FLIGHTS (FLIGHT_DB.FCT_FLIGHTS) (STAGING_GOLD)' name='federated.03cl6f21ttlmtr191xbi11jvzn29' />
          </datasources>
          <datasource-dependencies datasource='federated.03cl6f21ttlmtr191xbi11jvzn29'>
            <column caption='Alt Baro' datatype='integer' name='[ALT_BARO]' role='measure' type='quantitative' />
            <column caption='Altitude Band' datatype='string' name='[Calculation_0302656257601544]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [ALT_BARO] &gt;= 40000 THEN &quot;FL400+ (High Cruise)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 35000 THEN &quot;FL350-400 (Cruise)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 30000 THEN &quot;FL300-350 (Cruise)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 25000 THEN &quot;FL250-300 (Cruise)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 20000 THEN &quot;FL200-250 (Transition)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt;= 10000 THEN &quot;FL100-200 (Climb/Descent)&quot;&#13;&#10;ELSEIF [ALT_BARO] &gt; 0     THEN &quot;Below FL100 (Approach)&quot;&#13;&#10;ELSE &quot;Ground&quot;&#13;&#10;END' />
            </column>
            <column caption='Latest Snapshot' datatype='boolean' name='[Calculation_0437621223886848]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[SNAPSHOT_TS] =&#13;&#10;{ FIXED : MAX([SNAPSHOT_TS]) }' />
            </column>
            <column datatype='string' name='[HEX]' role='dimension' type='nominal' />
            <column caption='Snapshot Ts' datatype='datetime' name='[SNAPSHOT_TS]' role='dimension' type='ordinal' />
